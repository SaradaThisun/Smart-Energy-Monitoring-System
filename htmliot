<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart Home Energy Monitor</title>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
body{
    margin:0;
    font-family:Arial, Helvetica, sans-serif;
    background:#0f172a;
    color:white;
    text-align:center;
}

header{
    background:#111827;
    padding:20px;
    font-size:24px;
    letter-spacing:2px;
}

.container{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
    padding:20px;
}

.card{
    background:#1e293b;
    padding:20px;
    border-radius:12px;
    box-shadow:0 0 15px rgba(0,0,0,0.4);
}

.card h2{
    margin:0;
    font-size:18px;
    color:#94a3b8;
}

.value{
    font-size:32px;
    margin-top:10px;
    color:#22d3ee;
}

button{
    padding:12px 20px;
    margin:10px;
    border:none;
    border-radius:6px;
    font-size:16px;
    cursor:pointer;
}

.on-btn{
    background:#16a34a;
    color:white;
}

.off-btn{
    background:#dc2626;
    color:white;
}

.graph-container{
    width:90%;
    margin:30px auto;
    background:#1e293b;
    padding:20px;
    border-radius:12px;
}

footer{
    margin-top:20px;
    padding:15px;
    background:#111827;
    font-size:14px;
    color:#94a3b8;
}
</style>
</head>

<body>

<header>
SMART HOME ENERGY MONITOR
</header>

<div class="container">

<div class="card">
<h2>Voltage</h2>
<div class="value" id="voltage">230 V</div>
</div>

<div class="card">
<h2>Current</h2>
<div class="value" id="current">5 A</div>
</div>

<div class="card">
<h2>Power</h2>
<div class="value" id="power">1150 W</div>
</div>

<div class="card">
<h2>Energy</h2>
<div class="value" id="energy">0.52 kWh</div>
</div>

<div class="card">
<h2>Temperature</h2>
<div class="value" id="temperature">32 °C</div>
</div>

</div>

<div>
<button class="on-btn">Relay ON</button>
<button class="off-btn">Relay OFF</button>
</div>

<div class="graph-container">
<canvas id="powerChart"></canvas>
</div>

<footer>
Real-time Energy Monitoring Dashboard
</footer>

<script>
const ctx = document.getElementById('powerChart').getContext('2d');

const powerChart = new Chart(ctx, {
    type: 'line',
    data: {
        labels: ["1","2","3","4","5"],
        datasets: [{
            label: "Power (W)",
            data: [1000,1200,1100,1300,1250],
            borderColor: "#22d3ee",
            borderWidth: 2,
            fill: false
        }]
    },
    options: {
        responsive: true,
        scales: {
            y: {
                beginAtZero: true
            }
        }
    }
});
</script>

</body>
</html>